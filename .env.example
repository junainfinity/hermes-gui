# Hermes Web UI — environment variables
#
# These are read by Vite at build time and embedded into the static bundle.
# They are NOT secrets — the user supplies their API key through the UI at
# runtime and we store it in localStorage.

# Hermes API server base URL. Change if you ran `hermes gateway` on a
# non-default host/port.
VITE_HERMES_BASE_URL=http://127.0.0.1:8642

# Optional: skip the "paste your API key" onboarding dialog by baking a key
# into the bundle. Only suitable for local dev. NEVER set this in a
# distributed build.
# VITE_DEV_API_KEY=
